<Page x:Class="FjernVarmeFyn.Views.AdminFeedbackReview"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FjernVarmeFyn.Views"
      xmlns:root="clr-namespace:FjernVarmeFyn"
      mc:Ignorable="d" 
      d:DesignHeight="1000" d:DesignWidth="2000"
      Title="AdminFeedbackReview">

    <Page.Resources>
        <!-- Common style for all navigation buttons -->
        <Style x:Key="NavButtonStyle" TargetType="{x:Type Button}">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="{x:Type Button}">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="DarkGoldenrod"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <!-- Left side for the existing content -->
            <ColumnDefinition Width="3*"/>
            <!-- Right side for new content -->
            <ColumnDefinition Width="2*"/>
        </Grid.ColumnDefinitions>

        <!-- Left side with ListBox -->
        <Grid Grid.Row="1" Grid.Column="0" Margin="0,0,15,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>

            </Grid.RowDefinitions>




            <!-- Filtering and Sorting Options -->
            <Grid Grid.Row="1" Margin="0,0,0,10">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Type Filter (Wishes/Feedback) -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Sortering:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox Width="141" 
  ItemsSource="{Binding SortOptions}" 
  SelectedItem="{Binding SelectedSortOption, Mode=TwoWay}" />
                </StackPanel>

            </Grid>

            <!-- ListView with auto-height rows -->
            <ListView Grid.Row="2" 
      BorderThickness="1" 
      BorderBrush="#CCCCCC"
      ItemsSource="{Binding FeedbackList}"
      SelectedItem="{Binding SelectedFeedback, Mode=TwoWay}">
                <ListView.View>
                    <GridView AllowsColumnReorder="False">
                        <GridViewColumn Header="Emne" Width="Auto">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FeedbackSubject}" 
                               FontWeight="SemiBold" 
                               Margin="0,5" 
                               TextWrapping="Wrap" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Ticket" Width="Auto">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding FeedbackID}" 
                               Margin="0,5" 
                               MinWidth="70"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="System" Width="Auto">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding System}" 
                               Margin="0,5" 
                               MinWidth="80"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Status" Width="Auto">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Status}" 
                               Margin="0,5" 
                               MinWidth="100"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Handling" Width="Auto">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Slet" 
                                        Style="{StaticResource NavButtonStyle}"
                                        Padding="5,3" 
                                        Width="70" 
                                        Margin="5"
                                        Command="{Binding DataContext.DeleteFeedbackCommand, RelativeSource={RelativeSource AncestorType=ListView}}"
                                        CommandParameter="{Binding}" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <GridViewColumn Header="Prioritet" Width="Auto">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Criticality}" 
                             Width="80" 
                             Margin="5" />
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>
            </ListView>
            <!-- Search Bar -->
            <DockPanel Grid.Row="3" LastChildFill="True" Margin="0,10,0,10">
                <TextBlock Text="Søg:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox VerticalAlignment="Center" Height="24"/>
            </DockPanel>
        </Grid>

        <!-- Right side area for additional content -->
        <Grid Grid.Row="1" Grid.Column="1" Margin="15,0,0,0">
            <!-- Details content -->
            <ScrollViewer VerticalScrollBarVisibility="Disabled">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Emne Section  -->
                    <GroupBox Header="Emne" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                        <TextBox Text="{Binding CurrentFeedback.FeedbackSubject}" TextWrapping="Wrap" Margin="5"/>
                    </GroupBox>

                    <!-- System Section -->
                    <GroupBox Header="System" Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                        <TextBox Text="{Binding CurrentFeedback.System, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                    </GroupBox>

                    <!-- Ticket Section -->
                    <GroupBox Header="Ticket" Grid.Row="2" Grid.Column="0" Margin="5">
                        <TextBox Text="{Binding CurrentFeedback.FeedbackID, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="5"/>
                    </GroupBox>

                    <!-- Status Section -->
                    <GroupBox Header="Status" Grid.Row="2" Grid.Column="1" Margin="5">
                        <ComboBox ItemsSource="{Binding FeedbackStatusList}" 
          SelectedItem="{Binding CurrentFeedback.Status, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
          Margin="5" />
                    </GroupBox>

                    <!-- User Priority Section -->
                    <GroupBox Header="Prioritet" Grid.Row="3" Grid.Column="0" Margin="5">
                        <ComboBox ItemsSource="{Binding FeedbackCriticalityList}" 
                SelectedItem="{Binding CurrentFeedback.Criticality, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Margin="5" />
                    </GroupBox>

                    <GroupBox Header="Type" Grid.Row="3" Grid.Column="1" Margin="5">
                        <ComboBox ItemsSource="{Binding FeedbackTypeList}" 
                SelectedItem="{Binding CurrentFeedback.Type, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                Margin="5" />
                    </GroupBox>

                    <!-- Description Section  -->
                    <GroupBox Header="Beskrivelse" Grid.Row="4" Grid.Column="0" Grid.ColumnSpan="2" Margin="5">
                        <TextBox Text="{Binding CurrentFeedback.Description, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                     TextWrapping="Wrap" 
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     MinHeight="200"
                     Margin="5,0,5,0"
                     Padding="5"
                     BorderThickness="0" Height="623"/>
                    </GroupBox>

                    <Button Content="Indsend" 
                        Command="{Binding SubmitFeedbackCommand}"
                        Style="{StaticResource NavButtonStyle}"
                        Width="80" 
                        Padding="5,3" 
                        Grid.Row="5" 
                        Grid.Column="3" 
                        Grid.ColumnSpan="2"/>

                    <Button Content="Opdater" 
                        Command="{Binding UpdateFeedbackCommand}"
                        Style="{StaticResource NavButtonStyle}"
                        Width="80" 
                        Padding="5,3" 
                        Grid.Row="5" 
                        Grid.Column="0" 
                        Grid.ColumnSpan="2"/>

                    <Button Content="Nyt feedback" 
                        Click="FeedBack_Click"
                        Style="{StaticResource NavButtonStyle}"
                        Padding="5,3" 
                        Grid.Row="5" 
                        Grid.Column="0" 
                        VerticalAlignment="Center"
                        Margin="150,0,118,0" Height="34"/>
                </Grid>
            </ScrollViewer>
        </Grid>
    </Grid>
</Page>
