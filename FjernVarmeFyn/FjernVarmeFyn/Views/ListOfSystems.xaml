<Page x:Class="FjernVarmeFyn.Views.ListOfSystems"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FjernVarmeFyn.Views"
      xmlns:root="clr-namespace:FjernVarmeFyn"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1600"
      Title="ListOfSystems">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <!-- Content Area -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Filtering and Sorting Options -->
            <Grid Grid.Row="0" Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- Group Filter -->
                <StackPanel Orientation="Horizontal" Grid.Column="0" Margin="0,0,15,0">
                    <TextBlock Text="Gruppe:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox Width="140" SelectedIndex="0">
                        <ComboBoxItem Content="Alle"/>
                        <ComboBoxItem Content="Gruppe 1"/>
                        <ComboBoxItem Content="Gruppe 2"/>
                        <ComboBoxItem Content="Gruppe 3"/>
                    </ComboBox>
                </StackPanel>

                <!-- System Filter -->
                <StackPanel Orientation="Horizontal" Grid.Column="1" Margin="0,0,15,0">
                    <TextBlock Text="System:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox Width="140" SelectedIndex="0">
                        <ComboBoxItem Content="Alle"/>
                        <ComboBoxItem Content="System 1"/>
                        <ComboBoxItem Content="System 2"/>
                        <ComboBoxItem Content="System 3"/>
                    </ComboBox>
                </StackPanel>

                <!-- Type Filter (Wishes/Feedback) -->
                <StackPanel Orientation="Horizontal" Grid.Column="2" Margin="0,0,15,0">
                    <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox Width="140" SelectedIndex="0">
                        <ComboBoxItem Content="Alle"/>
                        <ComboBoxItem Content="Ønsker"/>
                        <ComboBoxItem Content="Feedback"/>
                    </ComboBox>
                </StackPanel>

                <!-- Status Filter -->
                <StackPanel Orientation="Horizontal" Grid.Column="3">
                    <TextBlock Text="Status:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                    <ComboBox Width="140" SelectedIndex="0">
                        <ComboBoxItem Content="Alle"/>
                        <ComboBoxItem Content="Åben"/>
                        <ComboBoxItem Content="Lukket"/>
                        <ComboBoxItem Content="Under behandling"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <!-- ListView - now takes all available space -->
            <ListView Grid.Row="1" 
                      BorderThickness="1" 
                      BorderBrush="#CCCCCC"
                      Margin="0,0,0,10"
                      ItemsSource="{Binding SystemItems}">

                <ListView.ItemContainerStyle>
                    <Style TargetType="{x:Type ListViewItem}">
                        <Setter Property="Height" Value="Auto"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                    </Style>
                </ListView.ItemContainerStyle>

                <ListView.View>
                    <GridView AllowsColumnReorder="False">
                        <!-- System name column -->
                        <GridViewColumn Header="System navn" Width="400">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Emne}" FontWeight="SemiBold" Margin="5" TextWrapping="Wrap"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Group column -->
                        <GridViewColumn Header="Gruppe" Width="150">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding Ticket}" Margin="5"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Feedback button -->
                        <GridViewColumn Header="Feedback" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Feedback" Padding="5,3" MinWidth="80" Margin="5"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>

                        <!-- Info button -->
                        <GridViewColumn Header="Info" Width="100">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Content="Info" Padding="5,3" MinWidth="80" Margin="5"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                    </GridView>
                </ListView.View>

                <!-- Sample items for design-time preview - these will be replaced by proper data binding -->
                <ListViewItem>
                    <root:TempFeedbackModel Emne="Problem med login" Ticket="T-1001" System="Login" Status="Åben" AdminPriority="2" Priority="5"/>
                </ListViewItem>
                <ListViewItem>
                    <root:TempFeedbackModel Emne="Fejl i rapportmodul" Ticket="T-1002" System="Rapporter" Status="Under behandling" AdminPriority="1" Priority="3"/>
                </ListViewItem>
                <ListViewItem>
                    <root:TempFeedbackModel Emne="Forslag til ny funktion - meget lang beskrivelse der skal vises korrekt i listen og ikke blive afkortet" Ticket="T-1003" System="Dashboard" Status="Åben" AdminPriority="3" Priority="4"/>
                </ListViewItem>
            </ListView>

            <!-- Search Bar -->
            <DockPanel Grid.Row="2" LastChildFill="True">
                <TextBlock Text="Søg:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                <TextBox VerticalAlignment="Center" Height="30"/>
            </DockPanel>
        </Grid>
    </Grid>
</Page>