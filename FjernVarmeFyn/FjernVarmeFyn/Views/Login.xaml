<Page x:Class="FjernVarmeFyn.Views.Login"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FjernVarmeFyn.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="Login">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition/>
            <RowDefinition/>
            <RowDefinition/>
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition/>
            <ColumnDefinition/>
            <ColumnDefinition/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Row="0" Grid.Column="1">
            <Image Source="/Images/Logo.jpg"  
        HorizontalAlignment="Center" Margin="0,0,0,0"/>
        </StackPanel>
        
        <StackPanel Grid.Row="1" Grid.Column="1">
            <Label  Content="E-mail">
            </Label>
        <TextBox></TextBox>

            <Label  Content="Adganskode" Margin="0,30,0,0">
            </Label>
            <TextBox></TextBox>
            <Button Content="Login" Margin="165,10,0,0" Width="100"></Button>
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1">
            <Button Content="Glemt adgangskode" Margin="0,30,45,100" Width="120" ></Button>
            <Button Content="Opret bruger" Margin="0,30,0,100" Width="100"></Button>
        </StackPanel>

    </Grid>
</Page>
