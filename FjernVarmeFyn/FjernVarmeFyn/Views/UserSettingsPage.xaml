<Page x:Class="FjernVarmeFyn.Views.UserSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FjernVarmeFyn.Views"
      mc:Ignorable="d" 
      d:DesignHeight="900" d:DesignWidth="1600"
      Title="UserSettingsPage">

    <Page.Resources>
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="DarkGoldenrod"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid HorizontalAlignment="Center" VerticalAlignment="Center" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <ScaleTransform ScaleX="0.9" ScaleY="0.9" />
        </Grid.RenderTransform>


        <Grid Width="1600" Height="850" Margin="22,9,-72,-9" Grid.RowSpan="2">
            <Button Content="Tilbage" HorizontalAlignment="Left" Margin="0,821,0,0" VerticalAlignment="Top" Style="{StaticResource CustomButtonStyle}" Height="29" Width="97"/>
            <Button Content="Gem" HorizontalAlignment="Left" Margin="761,202,0,0" VerticalAlignment="Top" Style="{StaticResource CustomButtonStyle}" Height="46" Width="71" RenderTransformOrigin="0.607,-1.19"/>
            <Label Content="Brugerindstillinger" HorizontalAlignment="Left" Margin="628,52,0,0" VerticalAlignment="Top" FontSize="24"/>
            <TextBox TextWrapping="Wrap" Text="Brugernavn" Margin="630,108,766,720"/>
            <TextBox TextWrapping="Wrap" Text="Telefon nummer" Margin="630,135,766,693"/>
            <TextBox TextWrapping="Wrap" Text="E-Mail" Margin="630,162,766,667"/>

        </Grid>
    </Grid>
</Page>
