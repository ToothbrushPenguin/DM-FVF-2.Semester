<Page x:Class="FjernVarmeFyn.Views.FeedbackPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:FjernVarmeFyn.Views"
      mc:Ignorable="d" 
      d:DesignHeight="450" d:DesignWidth="800"
      Title="FeedbackPage">

    <Page.Resources>
        <Style x:Key="CustomButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Black"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="DarkGoldenrod"/>
                </Trigger>
                <Trigger Property="IsPressed" Value="True">
                    <Setter Property="Background" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <Label Content="System:" HorizontalAlignment="Center" Margin="0,21,0,0" VerticalAlignment="Top" Width="128"/>
        <ComboBox HorizontalAlignment="Left" Margin="342,52,0,0" VerticalAlignment="Top" Width="120"/>
        <TextBox HorizontalAlignment="Left" Margin="340,90,0,0" TextWrapping="Wrap" Text="Navn" VerticalAlignment="Top" Width="124"/>
        <TextBox HorizontalAlignment="Left" Margin="340,120,0,0" TextWrapping="Wrap" Text="E-Mail" VerticalAlignment="Top" Width="124"/>
        <TextBox HorizontalAlignment="Left" Margin="340,150,0,0" TextWrapping="Wrap" Text="Telefon nummber" VerticalAlignment="Top" Width="124"/>
        <TextBox HorizontalAlignment="Left" Margin="340,200,0,0" TextWrapping="Wrap" Text="Feedback emne" VerticalAlignment="Top" Width="124"/>
        <TextBox HorizontalAlignment="Center" Margin="0,230,0,0" TextWrapping="Wrap" Text="Beskrivelse" VerticalAlignment="Top" Width="300" Height="175"/>

        <Button Content="Upload Fil" HorizontalAlignment="Left" Margin="250,420,0,0" VerticalAlignment="Top" Width="60" Style="{StaticResource CustomButtonStyle}"/>
        <Button Content="Tilbage" HorizontalAlignment="Left" Margin="10,408,0,0" VerticalAlignment="Top" Style="{StaticResource CustomButtonStyle}"/>
        <Button Content="Indsend" HorizontalAlignment="Left" Margin="748,408,0,0" VerticalAlignment="Top" Style="{StaticResource CustomButtonStyle}"/>
        <ComboBox HorizontalAlignment="Left" Margin="430,414,0,0" VerticalAlignment="Top" Width="120" Text="Type af feedback" />

    </Grid>
</Page>
